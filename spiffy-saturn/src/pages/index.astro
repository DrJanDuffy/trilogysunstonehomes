---
import '../styles/global.css';
// Component Imports
import Button from '../components/Button.astro';

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Trilogy Sunstone Homes | Las Vegas 55+ Community</title>
		<meta name="description" content="Discover Trilogy Sunstone, Las Vegas' premier 55+ active lifestyle community. Browse new homes priced $500k–$700k, explore amenities, and connect with Dr. Jan Duffy, your local expert." />
		<link rel="canonical" href="https://trilogysunstonehomes.pages.dev/" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://trilogysunstonehomes.pages.dev/" />
		<meta property="og:title" content="Trilogy Sunstone Homes | Las Vegas 55+ Community" />
		<meta property="og:description" content="Las Vegas' premier 55+ active lifestyle community. Browse new homes, explore amenities, and connect with Dr. Jan Duffy." />
		<meta property="og:image" content="https://trilogysunstonehomes.pages.dev/og-image.jpg" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Trilogy Sunstone Homes | Las Vegas 55+ Community" />
		<meta name="twitter:description" content="Las Vegas' premier 55+ active lifestyle community. Browse homes $500k–$700k with Dr. Jan Duffy." />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "RealEstateAgent",
			"name": "Dr. Jan Duffy — Trilogy Sunstone Specialist",
			"url": "https://trilogysunstonehomes.pages.dev/",
			"telephone": "+1-702-842-2276",
			"email": "DrDuffy@bhhsnv.com",
			"description": "Dr. Jan Duffy is a real estate specialist serving the Trilogy Sunstone 55+ community in Las Vegas, NV with Berkshire Hathaway HomeServices Nevada Properties.",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Las Vegas",
				"addressRegion": "NV",
				"addressCountry": "US"
			},
			"areaServed": { "@type": "Place", "name": "Trilogy Sunstone, Las Vegas, NV" },
			"memberOf": { "@type": "Organization", "name": "Berkshire Hathaway HomeServices Nevada Properties" }
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "FAQPage",
			"mainEntity": [
				{
					"@type": "Question",
					"name": "What is Trilogy Sunstone?",
					"acceptedAnswer": { "@type": "Answer", "text": "Trilogy Sunstone is a premier 55+ active lifestyle community in Las Vegas, Nevada, featuring new construction homes priced from $500,000 to $700,000 with resort-style amenities." }
				},
				{
					"@type": "Question",
					"name": "Who can help me buy a home at Trilogy Sunstone?",
					"acceptedAnswer": { "@type": "Answer", "text": "Dr. Jan Duffy of Berkshire Hathaway HomeServices Nevada Properties specializes in Trilogy Sunstone and can guide you through buying a home in this community." }
				},
				{
					"@type": "Question",
					"name": "What is the price range for Trilogy Sunstone homes?",
					"acceptedAnswer": { "@type": "Answer", "text": "Homes in Trilogy Sunstone are generally priced between $500,000 and $700,000, offering new construction with premium 55+ amenities." }
				}
			]
		})} />
		<!-- RealScout Widget Script and Style -->
		<script src="https://em.realscout.com/widgets/realscout-web-components.umd.js" type="module"></script>
		<style>
		  realscout-office-listings {
		    --rs-listing-divider-color: rgb(101, 141, 172);
		    width: 100%;
		  }
		</style>
	</head>

	<body class="bg-[#F7F9FC] text-[#0A2540]">
		<main class="min-h-screen flex flex-col">
			<!-- Hero Section -->
			<section class="relative flex flex-col items-center justify-center min-h-[60vh] bg-gradient-to-br from-[#3A8DDE] to-[#16B286] text-white shadow-lg">
				<h1 class="text-4xl md:text-6xl font-bold mb-4 drop-shadow">Find Your Dream Home at Trilogy Sunstone</h1>
				<p class="text-lg md:text-2xl mb-8 max-w-xl text-center">Las Vegas' premier 55+ active lifestyle community. Discover new homes, amenities, and a vibrant neighborhood.</p>
				<Button class="bg-white text-[#3A8DDE] font-semibold px-8 py-3 rounded shadow hover:bg-[#F7F9FC] transition">Get Started</Button>
			</section>
			<!-- Pain Point Section -->
			<section class="py-16 px-4 bg-white shadow-md">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-2xl md:text-3xl font-semibold mb-4">Tired of searching endless listings?</h2>
					<p class="text-lg text-[#3A8DDE]">We simplify your home search with curated listings, expert guidance, and exclusive community insights.</p>
				</div>
			</section>
			<!-- Solution Section -->
			<section class="py-16 px-4 bg-[#F7F9FC] shadow-md">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-2xl md:text-3xl font-semibold mb-4">A Better Way to Buy</h2>
					<ul class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
						<li class="bg-white rounded-lg p-6 shadow">Personalized Home Matches</li>
						<li class="bg-white rounded-lg p-6 shadow">Neighborhood & Amenity Insights</li>
						<li class="bg-white rounded-lg p-6 shadow">Guided Buyer Journey</li>
					</ul>
				</div>
			</section>
			<!-- Social Proof Section -->
			<section class="py-16 px-4 bg-white shadow-md">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-2xl md:text-3xl font-semibold mb-4">What Buyers Are Saying</h2>
					<div class="flex flex-col md:flex-row gap-8 justify-center mt-8">
						<blockquote class="bg-[#F7F9FC] p-6 rounded shadow max-w-sm mx-auto">“The process was so easy and the community is amazing!”<br/><span class="block mt-2 font-semibold text-[#16B286]">— Linda S.</span></blockquote>
						<blockquote class="bg-[#F7F9FC] p-6 rounded shadow max-w-sm mx-auto">“I found my perfect home and made new friends right away.”<br/><span class="block mt-2 font-semibold text-[#3A8DDE]">— Mark T.</span></blockquote>
					</div>
				</div>
			</section>
			<!-- Interactive Tool Section (Widget Placeholder) -->
			<section class="py-16 px-4 bg-[#F7F9FC] shadow-md min-h-[480px] flex flex-col items-center justify-center relative z-[1]">
				<div class="max-w-2xl w-full">
					<h2 class="text-2xl md:text-3xl font-semibold mb-4 text-center">Explore Home Values & Listings</h2>
					<div class="w-full h-[400px] flex items-center justify-center border-2 border-dashed border-[#3A8DDE] rounded-lg bg-white shadow" id="widget-container">
						<!-- RealScout, Homebot, CloudCMA, Percy.ai widgets will be loaded here -->
						<realscout-office-listings agent-encoded-id="QWdlbnQtMjI1MDUw" sort-order="NEWEST" listing-status="For Sale" property-types="SFR,MF" price-min="500000" price-max="700000"></realscout-office-listings>
					</div>
				</div>
			</section>
			<!-- Objection Handling Section -->
			<section class="py-16 px-4 bg-white shadow-md">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-2xl md:text-3xl font-semibold mb-4">Have Questions or Concerns?</h2>
					<p class="text-lg text-[#0A2540] mb-6">Our team is here to help you every step of the way. No pressure, just guidance.</p>
					<Button class="bg-[#16B286] text-white font-semibold px-8 py-3 rounded shadow hover:bg-[#3A8DDE] transition">Ask a Question</Button>
				</div>
			</section>
			<!-- Clear CTA Section -->
			<section class="py-16 px-4 bg-[#3A8DDE] text-white shadow-lg">
				<div class="max-w-4xl mx-auto text-center">
					<h2 class="text-2xl md:text-3xl font-semibold mb-4">Ready to Start Your Journey?</h2>
					<Button class="bg-white text-[#3A8DDE] font-semibold px-8 py-3 rounded shadow hover:bg-[#F7F9FC] transition">Get Your Free Guide</Button>
				</div>
			</section>
		</main>
	</body>
</html>
