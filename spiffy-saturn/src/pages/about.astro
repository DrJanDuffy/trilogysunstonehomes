---
import MainLayout from '../layouts/main.astro';
---

<MainLayout
	content={{
		title: 'About Trilogy Sunstone | Las Vegas 55+ Community',
		description:
			'Learn about Trilogy Sunstone, Las Vegas\' premier 55+ active lifestyle community. New homes, amenities, and a vibrant neighborhood in Southern Nevada.',
		canonicalURL: 'https://www.trilogysunstonehomes.com/about/',
	}}
>
	<main class="min-h-screen flex flex-col">
		<section class="relative flex flex-col items-center justify-center py-20 px-4 bg-gradient-to-br from-[#3A8DDE] to-[#16B286] text-white shadow-lg">
			<h1 class="text-4xl md:text-5xl font-bold mb-4 drop-shadow">About Trilogy Sunstone</h1>
			<p class="text-lg md:text-xl max-w-2xl text-center opacity-95">
				Las Vegas' premier 55+ active lifestyle community—where new homes, amenities, and a vibrant neighborhood come together.
			</p>
		</section>

		<section class="py-16 px-4 bg-white shadow-md">
			<div class="max-w-4xl mx-auto prose prose-lg">
				<h2 class="text-2xl md:text-3xl font-semibold text-[#0A2540] mb-6">Our Community</h2>
				<p class="text-[#0A2540] leading-relaxed mb-4">
					Trilogy Sunstone offers an active adult lifestyle in one of Las Vegas' most sought-after areas. Residents enjoy a close-knit community, thoughtfully designed new homes, and amenities built for an engaged, healthy life.
				</p>
				<p class="text-[#0A2540] leading-relaxed">
					Whether you're downsizing, relocating, or looking for your next chapter, we're here to help you find the right home and navigate the Trilogy Sunstone market with confidence.
				</p>
			</div>
		</section>

		<section class="py-16 px-4 bg-[#F7F9FC] shadow-md">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-2xl md:text-3xl font-semibold text-[#0A2540] mb-8">Why Trilogy Sunstone</h2>
				<ul class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
					<li class="bg-white rounded-lg p-6 shadow">
						<h3 class="font-semibold text-[#3A8DDE] mb-2">55+ Active Lifestyle</h3>
						<p class="text-[#0A2540] text-sm">Community designed for active adults with amenities and events that support your lifestyle.</p>
					</li>
					<li class="bg-white rounded-lg p-6 shadow">
						<h3 class="font-semibold text-[#3A8DDE] mb-2">New Construction</h3>
						<p class="text-[#0A2540] text-sm">Discover new homes built for comfort, accessibility, and modern living.</p>
					</li>
					<li class="bg-white rounded-lg p-6 shadow">
						<h3 class="font-semibold text-[#3A8DDE] mb-2">Las Vegas Location</h3>
						<p class="text-[#0A2540] text-sm">Enjoy Southern Nevada's climate, entertainment, and healthcare while living in a dedicated community.</p>
					</li>
				</ul>
			</div>
		</section>

		<section class="py-16 px-4 bg-white shadow-md">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-2xl md:text-3xl font-semibold text-[#0A2540] mb-4">Ready to Learn More?</h2>
				<p class="text-lg text-[#0A2540] mb-6">Explore listings or get in touch for personalized help.</p>
				<div class="flex flex-wrap gap-4 justify-center">
					<a href="/" class="inline-block appearance-none px-6 py-3 rounded-lg font-semibold shadow focus:outline-none focus:ring-2 focus:ring-offset-2 bg-[#3A8DDE] text-white hover:bg-[#2d7bc7] transition">
						View Listings
					</a>
					<a href="/contact" class="inline-block appearance-none px-6 py-3 rounded-lg font-semibold shadow focus:outline-none focus:ring-2 focus:ring-offset-2 bg-[#16B286] text-white hover:bg-[#3A8DDE] transition">
						Contact Us
					</a>
				</div>
			</div>
		</section>
	</main>
</MainLayout>
