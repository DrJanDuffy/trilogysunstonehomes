---
import MainLayout from '../layouts/main.astro';

const localBusinessSchema = {
	'@context': 'https://schema.org',
	'@type': 'RealEstateAgent',
	name: 'Trilogy Sunstone Homes',
	description: 'Real estate and homes at Trilogy Sunstone, Las Vegas 55+ active adult community.',
	url: 'https://www.trilogysunstonehomes.com',
	telephone: '+1-702-500-1942',
	areaServed: { '@type': 'City', name: 'Las Vegas', containedInPlace: { '@type': 'State', name: 'Nevada' } },
};
---

<MainLayout
	content={{
		title: 'Contact | Trilogy Sunstone Homes',
		description:
			'Get in touch about homes and real estate at Trilogy Sunstone, Las Vegas\' premier 55+ active lifestyle community. We\'re here to help.',
		canonicalURL: 'https://www.trilogysunstonehomes.com/contact/',
	}}
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
	</Fragment>
	<main class="min-h-screen flex flex-col">
		<section class="relative flex flex-col items-center justify-center py-20 px-4 bg-gradient-to-br from-[#3A8DDE] to-[#16B286] text-white shadow-lg">
			<h1 class="text-4xl md:text-5xl font-bold mb-4 drop-shadow">Contact Us</h1>
			<p class="text-lg md:text-xl max-w-2xl text-center opacity-95">
				Questions about Trilogy Sunstone homes? We're here to help.
			</p>
		</section>

		<section class="py-16 px-4 bg-white shadow-md">
			<div class="max-w-2xl mx-auto">
				<h2 class="text-2xl font-semibold text-[#0A2540] mb-6">Get in Touch</h2>
				<div class="space-y-6 text-[#0A2540]">
					<p class="text-lg">
						Reach out for listings, community information, or to schedule a visit to Trilogy Sunstone.
					</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a
							href="tel:+17025001942"
							class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold bg-[#16B286] text-white hover:bg-[#3A8DDE] transition shadow"
						>
							Call (702) 500-1942
						</a>
						<a
							href="/"
							class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold border-2 border-[#3A8DDE] text-[#3A8DDE] hover:bg-[#3A8DDE] hover:text-white transition"
						>
							View Listings
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="py-16 px-4 bg-[#F7F9FC] shadow-md">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-2xl font-semibold text-[#0A2540] mb-4">Trilogy Sunstone Homes</h2>
				<p class="text-[#0A2540]">Las Vegas, NV · 55+ active lifestyle community</p>
			</div>
		</section>
	</main>
</MainLayout>
