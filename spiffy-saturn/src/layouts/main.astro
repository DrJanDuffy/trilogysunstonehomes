---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
	content: {
		title: string;
		description?: string;
		canonicalURL?: string;
	};
}

const { content } = Astro.props;
// Optional: set PUBLIC_GSC_VERIFICATION in env (e.g. .env or Cloudflare Pages env) to the code from
// Google Search Console → Settings → Ownership verification → HTML tag. Do not commit the real code.
const gscCode = import.meta.env.PUBLIC_GSC_VERIFICATION;
const canonical = content.canonicalURL ?? 'https://www.trilogysunstonehomes.com/';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{content.title}</title>
		{content.description && <meta name="description" content={content.description} />}
		<link rel="canonical" href={canonical} />
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
		{gscCode && <meta name="google-site-verification" content={gscCode} />}
		<slot name="head" />
	</head>
	<body class="min-h-screen bg-[#F7F9FC] text-[#0A2540]">
		<Header />
		<slot />
	</body>
</html>
